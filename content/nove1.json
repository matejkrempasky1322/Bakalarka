"strong","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Úloha 1:","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"iCtbBOhGTa"}],"key":"YhVvLdeYxc"},{"type":"text","value":" Nastav zrýchlenie na zápornú hodnotu (brzdenie).\nAko sa zmení tvar grafu polohy?","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"YEr2zpW3ex"}],"key":"gtmGINCOh2"}],"key":"qog0feMrUI"},{"type":"blockquote","position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Úloha 2:","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"iDusboyhyh"}],"key":"hyfjlScQaq"},{"type":"text","value":" Zdvojnásob počiatočnú rýchlosť.\nO koľko sa zmenila brzdná dráha?","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"wPi4Y1UgiS"}],"key":"PFCUc8ubEJ"}],"key":"oVnNsZwwcn"}],"key":"sGhgiCSxCj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def simulacia_kinematiky(v0, a):\n    \"\"\"\n    Funkcia ktorá vypočíta a zobrazí grafy kinematiky pohybu vozidla.\n\n    Parametre:\n    v0 - počiatočná rýchlosť v m/s\n    a  - zrýchlenie v m/s² (záporná hodnota = brzdenie)\n    \"\"\"\n\n    # Vypočítame čas zastavenia ak vozidlo brzdí\n    # Vozidlo sa zastaví keď v(t) = 0, teda t = -v0/a\n    if a < 0 and v0 > 0:\n        t_stop = -v0 / a    # čas zastavenia v sekundách\n    else:\n        t_stop = 10         # predvolený čas simulácie ak vozidlo nezastavuje\n\n    # Vytvoríme pole 500 časových hodnôt od 0 po čas zastavenia\n    # Viac hodnôt = plynulejšie grafy\n    t = np.linspace(0, t_stop, 500)\n\n    # Výpočet fyzikálnych veličín pre každý časový okamih\n    s = v0 * t + 0.5 * a * t**2    # poloha v metroch podľa kinematickej rovnice\n    v = v0 + a * t                  # rýchlosť v m/s\n    acc = np.full_like(t, a)        # zrýchlenie je konštantné po celú dobu\n\n    # Výpočet brzdnej dráhy ak vozidlo brzdí\n    if a < 0 and v0 > 0:\n        s_brzd = v0**2 / (2 * abs(a))   # vzorec pre brzdnú dráhu\n    else:\n        s_brzd = None\n\n    # Vytvoríme tri grafy vedľa seba v jednom riadku\n    fig, (ax1, ax2, ax3) = plt.subplots(1, 3, figsize=(15, 4))\n    fig.suptitle(\n        f'Kinematika pohybu vozidla  |  $v_0$ = {v0} m/s  |  $a$ = {a} m/s²',\n        fontsize=13\n    )\n\n    # --- Graf 1: Poloha od času ---\n    ax1.plot(t, s, color='#00BFFF', linewidth=2)\n    ax1.set_xlabel('Čas (s)')\n    ax1.set_ylabel('Poloha (m)')\n    ax1.set_title('Poloha s(t)')\n    ax1.grid(True, alpha=0.3)\n    # Ak vozidlo brzdí, vyznačíme brzdnú dráhu červenou čiarkou\n    if s_brzd is not None:\n        ax1.axhline(y=s_brzd, color='red', linestyle='--', alpha=0.7,\n                    label=f'Brzdná dráha: {s_brzd:.1f} m')\n        ax1.legend()\n\n    # --- Graf 2: Rýchlosť od času ---\n    ax2.plot(t, v, color='#FFD700', linewidth=2)\n    ax2.set_xlabel('Čas (s)')\n    ax2.set_ylabel('Rýchlosť (m/s)')\n    ax2.set_title('Rýchlosť v(t)')\n    ax2.axhline(y=0, color='white', linestyle='-', alpha=0.3)  # nulová línia\n    ax2.grid(True, alpha=0.3)\n\n    # --- Graf 3: Zrýchlenie od času ---\n    ax3.plot(t, acc, color='#FF6B6B', linewidth=2)\n    ax3.set_xlabel('Čas (s)')\n    ax3.set_ylabel('Zrýchlenie (m/s²)')\n    ax3.set_title('Zrýchlenie a(t)')\n    ax3.axhline(y=0, color='white', linestyle='-', alpha=0.3)  # nulová línia\n    ax3.grid(True, alpha=0.3)\n\n    plt.tight_layout()  # automatické rozmiestnenie grafov aby sa neprekrývali\n    plt.show()\n\n    # Textový súhrn výsledkov pod grafmi\n    print(f'Počiatočná rýchlosť: {v0} m/s  ({v0*3.6:.1f} km/h)')\n    if s_brzd is not None:\n        print(f'Brzdná dráha: {s_brzd:.2f} m')\n        print(f'Čas zastavenia: {t_stop:.2f} s')\n\n# Vytvoríme interaktívne slidery prepojené so simulačnou funkciou\nwidgets.interact(\n    simulacia_kinematiky,\n    v0=widgets.FloatSlider(\n        value=20,           # predvolená počiatočná rýchlosť 20 m/s\n        min=0, max=50,      # rozsah 0 až 50 m/s\n        step=1,\n        description='v₀ (m/s):',\n        style={'description_width': 'initial'}\n    ),\n    a=widgets.FloatSlider(\n        value=-5,           # predvolené brzdenie -5 m/s²\n        min=-20, max=10,    # záporné hodnoty = brzdenie, kladné = zrýchlenie\n        step=0.5,\n        description='a (m/s²):',\n        style={'description_width': 'initial'}\n    )\n)","key":"rHy710xcUx"},{"type":"outputs","id":"NkX-RacMZwDqOYzDVpHej","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"0a12f96688144a3088ed381c518cef74\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"interactive(children=(FloatSlider(value=20.0, description='v₀ (m/s):', max=50.0, step=1.0, style=SliderStyle(d…","content_type":"text/plain"}}},"children":[],"key":"hOS4xn0eOw"},{"type":"output","jupyter_data":{"output_type":"execute_result","execution_count":2,"metadata":{},"data":{"text/plain":{"content":"<function __main__.simulacia_kinematiky(v0, a)>","content_type":"text/plain"}}},"children":[],"key":"R61I04nzxK"}],"key":"I6m3Jci7hb"}],"key":"msD41itU07"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# ÚLOHA 1: Zadanie číselnej odpovede s automatickou kontrolou\n# Študent vypočíta brzdnú dráhu a zadá výsledok do textového poľa\n# Systém odpoveď skontroluje a poskytne spätnú väzbu\n\nprint(\"📝 Otestuj svoje vedomosti:\")\nprint(\"Pri počiatočnej rýchlosti 20 m/s a brzdení -5 m/s²\")\nprint(\"aká je brzdná dráha? (výsledok zaokrúhli na celé číslo)\")\n\n# Textové pole kde študent zadá svoju odpoveď\nodpoved_pole = widgets.Text(\n    placeholder='Zadaj odpoveď v metroch...',\n    description='Brzdná dráha:',\n    style={'description_width': 'initial'},\n    layout=widgets.Layout(width='350px')\n)\n\n# Tlačidlo ktoré spustí kontrolu odpovede\ntlacidlo = widgets.Button(\n    description='Skontrolovať odpoveď',\n    button_style='info',\n    layout=widgets.Layout(width='200px')\n)\n\n# Výstupná oblasť kde sa zobrazí výsledok kontroly\nvystup = widgets.Output()\n\ndef skontroluj_odpoved(b):\n    \"\"\"\n    Funkcia ktorá skontroluje odpoveď študenta.\n    Správna odpoveď: s = v0² / (2*|a|) = 20² / (2*5) = 400/10 = 40 m\n    Povolená odchýlka je ±1 meter kvôli zaokrúhľovaniu.\n    \"\"\"\n    with vystup:\n        vystup.clear_output()   # vymaže predchádzajúci výstup pred novým\n        try:\n            # Načítame číselnú hodnotu zo vstupného poľa\n            student = float(odpoved_pole.value)\n\n            # Porovnáme so správnou odpoveďou s toleranciou ±1 m\n            if abs(student - 40.0) <= 1:\n                print('✅ Správne! Brzdná dráha je 40 m.')\n                print('   Výpočet: s = v₀² / (2·|a|) = 400 / 10 = 40 m')\n            else:\n                print('❌ Skús znova. Použi vzorec: s = v₀² / (2·|a|)')\n        except ValueError:\n            # Ak študent nezadal číslo, zobrazíme upozornenie\n            print('⚠️ Zadaj číselnú hodnotu.')\n\n# Prepojenie tlačidla s kontrolnou funkciou\ntlacidlo.on_click(skontroluj_odpoved)\n\n# Zobrazenie všetkých prvkov v správnom poradí\ndisplay(odpoved_pole, tlacidlo, vystup)","key":"tOopSGYBKV"},{"type":"outputs","id":"BtgDNicmcc3o742XZy1-Z","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"📝 Otestuj svoje vedomosti:\nPri počiatočnej rýchlosti 20 m/s a brzdení -5 m/s²\naká je brzdná dráha? (výsledok zaokrúhli na celé číslo)\n"},"children":[],"key":"DWfLT52rrJ"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"f83a1ba3ade3451e8c195ef751956f56\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Text(value='', description='Brzdná dráha:', layout=Layout(width='350px'), placeholder='Zadaj odpoveď v metroch…","content_type":"text/plain"}}},"children":[],"key":"RgduvgOLY2"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"875f4133c73147988fc6157ae01080a9\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Button(button_style='info', description='Skontrolovať odpoveď', layout=Layout(width='200px'), style=ButtonStyl…","content_type":"text/plain"}}},"children":[],"key":"NSgQv1zXBt"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"f46677787ed5466cab3dde34340812b0\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Output()","content_type":"text/plain"}}},"children":[],"key":"fXWpOtjuEb"}],"key":"WOmi2y3OcI"}],"key":"e7mtkyWFwb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# ÚLOHA 2: Výber správnej odpovede z ponúknutých možností\n# Študent vyberie jednu z možností a potvrdí výber tlačidlom\n# Správna odpoveď je podložená fyzikálnym zdôvodnením\n\nprint(\"🔘 Vyber správnu odpoveď:\")\nprint(\"Vodič ide rýchlosťou 60 km/h. Zdvojnásobí rýchlosť na 120 km/h.\")\nprint(\"Ako sa zmení brzdná dráha?\")\n\n# Skupina prepínačov s možnosťami odpovede\n# Len jedna možnosť môže byť vybratá naraz\nmoznosti = widgets.RadioButtons(\n    options=[\n        'Zdvojnásobí sa',\n        'Strojnásobí sa',\n        'Štvornásobí sa',\n        'Zostane rovnaká'\n    ],\n    description='Odpoveď:',\n    style={'description_width': 'initial'},\n    layout=widgets.Layout(width='400px')\n)\n\n# Tlačidlo na potvrdenie vybranej možnosti\ntlacidlo_mc = widgets.Button(\n    description='Potvrdiť odpoveď',\n    button_style='info',\n    layout=widgets.Layout(width='200px')\n)\n\n# Výstupná oblasť pre spätnú väzbu\nvystup_mc = widgets.Output()\n\ndef skontroluj_mc(b):\n    \"\"\"\n    Funkcia ktorá skontroluje vybranú možnosť.\n    Správna odpoveď: Štvornásobí sa.\n    Dôvod: s = v₀²/(2|a|) závisí kvadraticky od rýchlosti.\n    Pri dvojnásobnej rýchlosti: s = (2v₀)²/(2|a|) = 4·v₀²/(2|a|)\n    \"\"\"\n    with vystup_mc:\n        vystup_mc.clear_output()    # vymaže predchádzajúci výstup\n\n        if moznosti.value == 'Štvornásobí sa':\n            # Správna odpoveď s fyzikálnym vysvetlením\n            print('✅ Správne! Brzdná dráha závisí kvadraticky od rýchlosti.')\n            print('   s = v₀² / (2·|a|)  →  pri dvojnásobnej rýchlosti je s štvornásobná.')\n        else:\n            # Nesprávna odpoveď s nápoveďou\n            print('❌ Nie je správne. Nápoveda: pozri rovnicu s = v₀² / (2·|a|)')\n            print('   Zamysli sa čo sa stane ak v₀ nahradíš hodnotou 2·v₀')\n\n# Prepojenie tlačidla s kontrolnou funkciou\ntlacidlo_mc.on_click(skontroluj_mc)\n\n# Zobrazenie všetkých prvkov\ndisplay(moznosti, tlacidlo_mc, vystup_mc)","key":"wQeoioPcix"},{"type":"outputs","id":"FV1d2fYusQ_brqKfOyQc_","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"🔘 Vyber správnu odpoveď:\nVodič ide rýchlosťou 60 km/h. Zdvojnásobí rýchlosť na 120 km/h.\nAko sa zmení brzdná dráha?\n"},"children":[],"key":"jC4lJ0ZD0K"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"5118641dc62a449fa67dd4d7cd872964\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"RadioButtons(description='Odpoveď:', layout=Layout(width='400px'), options=('Zdvojnásobí sa', 'Strojnásobí sa'…","content_type":"text/plain"}}},"children":[],"key":"SQbp1DsGoG"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"6ff849f8b5fe4be5b040c7383728356b\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Button(button_style='info', description='Potvrdiť odpoveď', layout=Layout(width='200px'), style=ButtonStyle())","content_type":"text/plain"}}},"children":[],"key":"oYsJVsppHZ"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"046d70d938a34d849c6790be0082069f\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"Output()","content_type":"text/plain"}}},"children":[],"key":"UYtw7khtG1"}],"key":"OajQ4hfyQX"}],"key":"BzYjiaZou3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n#ÚLOHA 3: Doplňovačka - dosadzovanie do fyzikálneho vzorca\n# Študent vypočíta tri hodnoty a dosadí ich do rovnice\n# Každé pole sa kontroluje samostatne s individuálnou spätnou väzbou\n\nprint(\"✏️ Doplň správne hodnoty do rovnice brzdnej dráhy:\")\nprint(\"Vozidlo ide rýchlosťou v₀ = 30 m/s a brzdí zrýchlením a = -6 m/s²\")\nprint()\nprint(\"Brzdná dráha:  s = v₀² / (2 · |a|)  =  ___ / (2 · ___)  =  ___ m\")\nprint()\n\n# Vstupné pole pre prvú hodnotu: v₀² = 30² = 900\npole1 = widgets.FloatText(\n    description='v₀² =',\n    placeholder='?',\n    style={'description_width': 'initial'},\n    layout=widgets.Layout(width='200px')\n)\n\n# Vstupné pole pre druhú hodnotu: |a| = 6\npole2 = widgets.FloatText(\n    description='|a| =',\n    placeholder='?',\n    style={'description_width': 'initial'},\n    layout=widgets.Layout(width='200px')\n)\n\n# Vstupné pole pre výsledok: s = 900/12 = 75 m\npole3 = widgets.FloatText(\n    description='s =',\n    placeholder='? m',\n    style={'description_width': 'initial'},\n    layout=widgets.Layout(width='200px')\n)\n\n# Tlačidlo na overenie všetkých troch hodnôt naraz\ntlacidlo_d = widgets.Button(\n    description='Skontrolovať',\n    button_style='info',\n    layout=widgets.Layout(width='200px')\n)\n\n# Výstupná oblasť pre spätnú väzbu ku každému poľu\nvystup_d = widgets.Output()\n\ndef skontroluj_doplnk(b):\n    \"\"\"\n    Funkcia ktorá skontroluje všetky tri zadané hodnoty.\n    Správne hodnoty:\n    - v₀² = 30² = 900\n    - |a|  = |-6| = 6\n    - s    = 900 / (2·6) = 900 / 12 = 75 m\n    \"\"\"\n    with vystup_d:\n        vystup_d.clear_output()     # vymaže predchádzajúci výstup\n\n        # Zoznam chýb ktoré sa zobrazia na konci\n        chyby = []\n\n        # Kontrola prvého poľa: v₀² musí byť 900\n        if abs(pole1.value - 900) > 1:\n            chyby.append('❌ v₀² nie je správne. v₀ = 30 m/s, teda v₀² = 30² = ?')\n        else:\n            print('✅ v₀² = 900 – správne!')\n\n        # Kontrola druhého poľa: |a| musí byť 6\n        if abs(pole2.value - 6) > 0.1:\n            chyby.append('❌ |a| nie je správne. Zrýchlenie je -6 m/s², teda |a| = ?')\n        else:\n            print('✅ |a| = 6 – správne!')\n\n        # Kontrola tretieho poľa: výsledok musí byť 75 m\n        if abs(pole3.value - 75) > 1:\n            chyby.append('❌ Výsledok nie je správny. Dosaď správne hodnoty do vzorca.')\n        else:\n            print('✅ s = 75 m – správne!')\n\n        # Vypíšeme všetky chyby ak nejaké sú\n        for chyba in chyby:\n            print(chyba)\n\n        # Ak nie sú žiadne chyby zobrazíme gratulačnú správu\n        if not chyby:\n            print()\n            print('🎉 Výborne! Všetky hodnoty sú správne.')\n            print('   s = 900 / (2·6) = 900 / 12 = 75 m')\n\n# Prepojenie tlačidla s kontrolnou funkciou\ntlacidlo_d.on_click(skontroluj_doplnk)\n\n# Zobrazenie všetkých vstupných polí a tlačidla\ndisplay(pole1, pole2, pole3, tlacidlo_d, vystup_d)","key":"z0rlBbfv8v"},{"type":"outputs","id":"tFoIANfV3RhheFQ44LhiW","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"✏️ Doplň správne hodnoty do rovnice brzdnej dráhy:\nVozidlo ide rýchlosťou v₀ = 30 m/s a brzdí zrýchlením a = -6 m/s²\n\nBrzdná dráha:  s = v₀² / (2 · |a|)  =  ___ / (2 · ___)  =  ___ m\n\n"},"children":[],"key":"pLxQC211lI"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"71f01f84e63a4d04b29927594a25eebd\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"FloatText(value=0.0, description='v₀² =', layout=Layout(width='200px'), style=DescriptionStyle(description_wid…","content_type":"text/plain"}}},"children":[],"key":"WT08i0R29D"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"95157746e97347eb994275162d504c4c\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"FloatText(value=0.0, description='|a| =', layout=Layout(width='200px'), style=DescriptionStyle(description_wid…","content_type":"text/plain"}}},"children":[],"key":"nN1KAhE2cQ"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"application/vnd.jupyter.widget-view+json":{"content":"{\"model_id\":\"3af63cd5d3ea4ce9b5e16f44ff5f02c9\",\"version_major\":2,\"version_minor\":0}","content_type":"application/vnd.jupyter.widget-view+json"},"text/plain":{"content":"FloatText(value=0.0, desc